# LLM backend
# Option A — Ollama (recommended for local dev)
#   1. Install: https://ollama.com
#   2. Run:     ollama serve
#   3. Pull:    ollama pull llama3.2   (or any model you prefer)
#   4. The app will auto-detect Ollama and show a model picker in the sidebar.
OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL is optional when using Ollama — the sidebar lets you pick at runtime.
# Set it to pre-select a model (must be already pulled locally).
LLM_MODEL=

# Option B — External OpenAI-compatible server (vLLM, llama.cpp, OpenAI API, etc.)
#   Uncomment and fill in both lines to override Ollama:
# LLM_ENDPOINT=http://localhost:8000/v1
# LLM_MODEL=Qwen/Qwen3-8B-Instruct-AWQ

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Embeddings
EMBEDDING_MODEL=law-ai/InLegalBERT
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Vector store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=delhi_legal_kb

# Retrieval
TOP_K=8
RERANK_CONFIDENCE_THRESHOLD=0.55

# Paths
KB_ROOT=./knowledge_base
DATA_ROOT=./data
